#!/bin/bash

# Overwrite the user config for the Plymouth drive decryption and boot sequence with the Prometheus default and rebuild it.

sudo cp ~/.local/share/prometheus/default/plymouth/* /usr/share/plymouth/themes/prometheus/
sudo plymouth-set-default-theme prometheus

if command -v limine-mkinitcpio &>/dev/null; then
  sudo limine-mkinitcpio
else
  sudo mkinitcpio -P
fi
