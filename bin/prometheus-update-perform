#!/bin/bash

set -e

# Run the update inside a PTY so pacman/yay keep showing download progress
# while still logging the full session for later analysis.
if [[ -z $PROMETHEUS_UPDATE_LOGGED ]]; then
  script_command=$(printf '%q ' "$0" "$@")
  exec env PROMETHEUS_UPDATE_LOGGED=1 script -qefc "$script_command" "/tmp/prometheus-update.log"
fi

# Ensure screensaver/sleep doesn't set in during updates
hyprctl dispatch tagwindow +noidle &>/dev/null || true

# Perform all update steps
# prometheus-update-keyring
#prometheus-update-available-reset
prometheus-update-system-pkgs
#prometheus-migrate
prometheus-update-aur-pkgs
prometheus-update-orphan-pkgs
prometheus-hook post-update

prometheus-update-analyze-logs

prometheus-update-restart

# Re-enable screensaver/sleep after updates
hyprctl dispatch tagwindow -- -noidle &>/dev/null || true
