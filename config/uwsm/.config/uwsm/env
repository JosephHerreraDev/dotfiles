# Changes require a restart to take effect.

# Ensure Prometheus bins are in the path
export PROMETHEUS_PATH=$HOME/.local/share/prometheus
export PATH=$PROMETHEUS_PATH/bin:$PATH:$HOME/.local/bin

# Set default terminal and editor
source ~/.config/uwsm/default

# Activate mise if present on the system
prometheus-cmd-present mise && eval "$(mise activate bash --shims)"
